{% doc %}
  @prompt
    Zou je kunnen een website draaien binnenin een pagina, de website is https://app.sterapro.be
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-iframe-embed-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-iframe-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.iframe_height }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
  }

  .ai-iframe-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-iframe-embed-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-iframe-container-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }
  }
{% endstyle %}

<iframe-embed-{{ ai_gen_id }}
  class="ai-iframe-embed-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-iframe-container-{{ ai_gen_id }}">
    <iframe
      class="ai-iframe-{{ ai_gen_id }}"
      src="{{ block.settings.iframe_url }}"
      title="{{ block.settings.iframe_title }}"
      loading="lazy"
      {% if block.settings.allow_fullscreen %}allowfullscreen{% endif %}
    ></iframe>
  </div>
</iframe-embed-{{ ai_gen_id }}>

<script>
  (function() {
    class IframeEmbed{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const iframe = this.querySelector('.ai-iframe-{{ ai_gen_id }}');
        
        iframe.addEventListener('load', function() {
          console.log('Iframe loaded successfully');
        });

        iframe.addEventListener('error', function() {
          console.error('Error loading iframe');
        });
      }
    }

    customElements.define('iframe-embed-{{ ai_gen_id }}', IframeEmbed{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Website embed",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Website instellingen"
    },
    {
      "type": "url",
      "id": "iframe_url",
      "label": "Website URL"
    },
    {
      "type": "text",
      "id": "iframe_title",
      "label": "Iframe titel",
      "default": "Embedded website"
    },
    {
      "type": "checkbox",
      "id": "allow_fullscreen",
      "label": "Volledig scherm toestaan",
      "default": false
    },
    {
      "type": "header",
      "content": "Afmetingen"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop breedte",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "iframe_height",
      "label": "Desktop hoogte",
      "min": 300,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobiele hoogte",
      "min": 300,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "header",
      "content": "Stijl"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Achtergrondkleur",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Randkleur",
      "default": "#e6e6e6"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Randbreedte",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Randradius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Website embed"
    }
  ]
}
{% endschema %}
