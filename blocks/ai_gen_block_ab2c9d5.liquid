{% doc %}
  @prompt
    ik wil graag duidelijk maken dat dit een B2B product is. Particulieren kunnen dit ook bestellen maar prijzen voor bedrijven zijn op aanvraag, ja maar kan je er ook een knop bijsteken zodat bedrijven een account kunnen aanmaken 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-b2b-notice-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    margin: {{ block.settings.margin_top }}px 0 {{ block.settings.margin_bottom }}px 0;
  }

  .ai-b2b-notice__content-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .ai-b2b-notice__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
    margin-top: 2px;
  }

  .ai-b2b-notice__text-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-b2b-notice__heading-{{ ai_gen_id }} {
    margin: 0 0 8px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    line-height: 1.3;
  }

  .ai-b2b-notice__description-{{ ai_gen_id }} {
    margin: 0 0 12px 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
  }

  .ai-b2b-notice__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .ai-b2b-notice__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-b2b-notice-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-b2b-notice__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-b2b-notice-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-b2b-notice__content-{{ ai_gen_id }}">
    {% if block.settings.show_icon %}
      <div class="ai-b2b-notice__icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          <path d="M21 21v-2a4 4 0 0 0-3-3.85"></path>
        </svg>
      </div>
    {% endif %}
    <div class="ai-b2b-notice__text-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h3 class="ai-b2b-notice__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
      {% endif %}
      {% if block.settings.description != blank %}
        <div class="ai-b2b-notice__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}
      {% if block.settings.show_button %}
        <a href="{{ block.settings.button_link }}" class="ai-b2b-notice__button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

