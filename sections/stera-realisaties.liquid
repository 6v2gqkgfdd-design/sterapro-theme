{% comment %}
  Stera Pro — Realisaties (design-handoff §8).
  Kop + ghost-knop links, 3 stats (serif italic) rechts, rij van 4 foto's.
{% endcomment %}

<section class="stera-real color-{{ section.settings.color_scheme }}" style="background: rgb(var(--color-background)); padding: 76px 0;">
  <div class="stera-real__inner">
    <div class="stera-real__top">
      <div class="stera-real__copy">
        {% if section.settings.kicker != blank %}<div class="stera-kicker">{{ section.settings.kicker }}</div>{% endif %}
        <h2 class="stera-h2">{{ section.settings.title }}</h2>
        {% if section.settings.sub != blank %}<p class="stera-sub">{{ section.settings.sub }}</p>{% endif %}
        {% if section.settings.btn_label != blank %}
          <div style="margin-top: 28px;">
            <a class="stera-btn stera-btn--ghost stera-btn--small" href="{{ section.settings.btn_link | default: '#' }}">
              {{ section.settings.btn_label }}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
        {% endif %}
      </div>
      <div class="stera-real__stats">
        {% for block in section.blocks %}
          {% if block.type == 'stat' %}
            <div class="stera-real__stat" {{ block.shopify_attributes }}>
              <div class="stera-real__value">{{ block.settings.value }}</div>
              <div class="stera-real__label">{{ block.settings.label }}</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <div class="stera-real__photos">
      {% assign imgs = 'image_1,image_2,image_3,image_4' | split: ',' %}
      {% for key in imgs %}
        {% assign img = section.settings[key] %}
        {% if img != blank %}
          {{ img | image_url: width: 700 | image_tag: class: 'stera-real__img', loading: 'lazy' }}
        {% else %}
          <div class="stera-real__img stera-real__img--placeholder"></div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .stera-real__inner { max-width: 1320px; margin: 0 auto; padding: 0 24px; }
  .stera-real__top { display: flex; gap: 80px; align-items: flex-start; }
  .stera-real__copy { flex: 0 0 38%; }
  .stera-real__stats { flex: 1; display: flex; gap: 48px; justify-content: flex-end; padding-top: 8px; flex-wrap: wrap; }
  .stera-real__value {
    font-family: var(--font-accent--family);
    font-style: italic;
    font-weight: 400;
    font-size: 52px;
    line-height: 1;
    color: #2F5840;
  }
  .stera-real__label {
    margin-top: 8px;
    font-family: var(--font-body--family);
    font-size: 13.5px;
    color: rgba(var(--color-foreground), 0.62);
    max-width: 140px;
  }
  .stera-real__photos { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 40px; }
  .stera-real__img { width: 100%; height: 170px; object-fit: cover; border-radius: 12px; display: block; }
  .stera-real__img--placeholder { background: rgba(47,88,64,.12); }
  @media (max-width: 989px) {
    .stera-real__top { flex-direction: column; gap: 28px; }
    .stera-real__copy { flex: none; }
    .stera-real__stats { justify-content: flex-start; }
    .stera-real__photos { grid-template-columns: repeat(2, 1fr); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Stera realisaties",
  "max_blocks": 3,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Kleurenschema", "default": "scheme-1" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Realisaties" },
    { "type": "text", "id": "title", "label": "Titel", "default": "Groen dat al ademt" },
    { "type": "textarea", "id": "sub", "label": "Subtekst", "default": "Een greep uit de ruimtes die we inrichtten en onderhouden — van kantoor tot mosmuur." },
    { "type": "text", "id": "btn_label", "label": "Knoptekst", "default": "Bekijk realisaties" },
    { "type": "url", "id": "btn_link", "label": "Knoplink" },
    { "type": "image_picker", "id": "image_1", "label": "Foto 1" },
    { "type": "image_picker", "id": "image_2", "label": "Foto 2" },
    { "type": "image_picker", "id": "image_3", "label": "Foto 3" },
    { "type": "image_picker", "id": "image_4", "label": "Foto 4" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Cijfer",
      "settings": [
        { "type": "text", "id": "value", "label": "Waarde", "default": "XX" },
        { "type": "text", "id": "label", "label": "Label", "default": "locaties in onderhoud" }
      ]
    }
  ],
  "presets": [
    { "name": "Stera realisaties",
      "blocks": [
        { "type": "stat", "settings": { "value": "XX", "label": "locaties in onderhoud" } },
        { "type": "stat", "settings": { "value": "XX", "label": "jaar groene ervaring" } },
        { "type": "stat", "settings": { "value": "XX m²", "label": "mosmuur geplaatst" } }
      ] }
  ]
}
{% endschema %}
