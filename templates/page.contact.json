              },
              "blocks": {
                "text_7MBUrX": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Graag zelfs. We bekijken je ruimte, het licht en je stijl, en werken een voorstel op maat uit met foto’s en vaste prijzen — gratis en vrijblijvend.</p>",
                    "width": "100%",
