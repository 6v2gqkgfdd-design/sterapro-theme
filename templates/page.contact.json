              ]
            },
            "accordion_row_pMtdqt": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "Doen jullie ook onderhoud?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_4ajNMx": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Ja. Elke plant heeft een ingebouwde watermeter waardoor het onderhoud al heel eenvoudig is, maar je kan het ook volledig aan ons uitbesteden met een onderhoudsabonnement op maat.</p>",
                    "width": "100%",
                    "max_width": "normal",
