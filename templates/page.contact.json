              "blocks": {
                "text_MyKcGn": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Registreer je bedrijf met je BTW-nummer. Na goedkeuring log je in met een e-mailcode (geen wachtwoord) en bestel je rechtstreeks aan jouw prijzen.</p>",
