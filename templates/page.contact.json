            "accordion_row_aEkn6b": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Hoe snel leveren jullie?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_CyLYkB": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Na bestelling leveren en installeren we doorgaans binnen 2 à 3 weken. Wij plaatsen alles op de juiste plek en nemen het verpakkingsmateriaal mee.</p>",
                    "width": "100%",
